rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra Padrão: Apenas usuários logados podem ler/gravar
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // (Opcional) Regras Específicas para Auditoria futura
    // match /clients/{client} {
    //   allow read: if request.auth != null;
    //   allow write: if request.auth != null && request.auth.token.email.matches('.*@estemco[.]com[.]br');
    // }
  }
}
