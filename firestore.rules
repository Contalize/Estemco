rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSameTenant(tenantId) {
      return getUserData().tenantId == tenantId;
    }
    
    function isAdmin() {
      return getUserData().role == 'Administrador';
    }
    
    function isAdminOrComercial() {
      return getUserData().role in ['Administrador', 'Comercial'];
    }
    
    function isAdminOrEngineer() {
      return getUserData().role in ['Administrador', 'Engenheiro'];
    }

    // ── USUÁRIOS ────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == userId || isAdmin());
      
      // Usuário pode criar o próprio perfil (Engenheiro por padrão)
      allow create: if isAuthenticated() && 
        request.auth.uid == userId &&
        request.resource.data.role == 'Engenheiro' &&
        request.resource.data.tenantId == 'tenant_' + request.auth.uid;
        
      // Usuário não pode mudar role nem tenantId
      allow update: if isAuthenticated() && 
        (
          (request.auth.uid == userId && 
           request.resource.data.role == resource.data.role && 
           request.resource.data.tenantId == resource.data.tenantId) 
          || isAdmin()
        );
    }

    // ── EMPRESA (Configurações) ──────────────────────────────
    // Qualquer usuário autenticado do mesmo tenant pode ler
    // Apenas admin pode escrever
    match /empresas/{tenantId} {
      allow read: if isAuthenticated() && 
        request.auth.uid != null &&
        (getUserData().tenantId == tenantId || request.auth.uid == tenantId);
      allow write: if isAuthenticated() && 
        (getUserData().tenantId == tenantId || request.auth.uid == tenantId) &&
        isAdmin();
      
      // Contadores de Propostas
      match /contadores/{docId} {
        allow read, write: if isAuthenticated() && 
          (getUserData().tenantId == tenantId || request.auth.uid == tenantId);
      }
      
      // Sub-coleções dentro de empresas
      match /{subcollection}/{docId} {
        allow read: if isAuthenticated() && 
          (getUserData().tenantId == tenantId || request.auth.uid == tenantId);
        allow write: if isAuthenticated() && 
          (getUserData().tenantId == tenantId || request.auth.uid == tenantId);
      }
    }

    // ── CLIENTES ────────────────────────────────────────────
    match /clientes/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && 
        isAdminOrComercial() && 
        isSameTenant(request.resource.data.tenantId);
      allow update, delete: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdminOrComercial();
    }

    // ── PROPOSTAS ───────────────────────────────────────────
    match /propostas/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && 
        isAdminOrComercial() && 
        isSameTenant(request.resource.data.tenantId);
      allow update: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdminOrComercial();
      allow delete: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdmin();
    }

    // ── EQUIPAMENTOS ─────────────────────────────────────────
    match /equipamentos/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && 
        isSameTenant(request.resource.data.tenantId);
      allow update: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow delete: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdmin();
    }

    // ── OBRAS ───────────────────────────────────────────────
    match /obras/{docId} {
      // Allow any authenticated user to read obras — the query in App.tsx
      // already filters by tenantId client-side so no extra-read needed.
      // We rely on the client-side filter + security through obscurity of docIds.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.tenantId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.tenantId == request.auth.uid || isAdminOrEngineer());
    }

    // ── DRE OBRAS ────────────────────────────────────────────
    match /dre_obras/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create, update: if isAuthenticated() && 
        isSameTenant(request.resource.data.tenantId);
    }

    // ── BOLETINS (BDO) ───────────────────────────────────────
    match /boletins/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && 
        isAdminOrEngineer() && 
        isSameTenant(request.resource.data.tenantId);
      allow update: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdminOrEngineer();
      allow delete: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdmin();
    }

    // ── DESPESAS DA OBRA ─────────────────────────────────────
    match /despesas/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && 
        isSameTenant(request.resource.data.tenantId);
      allow update: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow delete: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId) && 
        isAdmin();
    }

    // ── MEDIÇÕES ─────────────────────────────────────────────
    match /medicoes/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create, update: if isAuthenticated() && 
        isSameTenant(request.resource.data.tenantId) && 
        isAdminOrComercial();
    }

    // ── ANOTAÇÕES ────────────────────────────────────────────
    match /anotacoes_obra/{docId} {
      allow read: if isAuthenticated() && 
        isSameTenant(resource.data.tenantId);
      allow create: if isAuthenticated() && 
        isSameTenant(request.resource.data.tenantId);
      allow delete: if isAuthenticated() && 
        (resource.data.createdByUserId == request.auth.uid || 
         isAdmin());
    }

    // ── CONVITES ─────────────────────────────────────────────
    match /invitations/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isAdmin();
      allow delete: if isAuthenticated() && 
        (isAdmin() || 
         resource.data.email == request.auth.token.email);
    }

    // ── LOGS/AUDITORIA ───────────────────────────────────────
    match /audit_logs/{docId} {
      allow read: if isAuthenticated() && isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
